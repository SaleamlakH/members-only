<form class="signup-form" action="/login" method="POST">
  <h1>Login</h1>

  <div class="auth-error"><%= locals.authError %></div>

  <div class="rows">
    <label for="email">Email</label>
    <input
      type="email"
      name="email"
      id="email"
      value="<%= locals.data?.email %>"
      required
    />
    <div class="error"><%= locals.errors?.email?.message %></div>
  </div>

  <div class="rows">
    <label for="password">Password</label>
    <input
      type="password"
      name="password"
      id="password"
      required
    />
    <div class="error"><%= locals.errors?.password?.message %></div>
  </div>

  <button>Login</button>
</form>
