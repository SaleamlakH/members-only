<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <base href="/">
    <link rel="stylesheet" href="style.css">
    <script src="script.js" defer></script>
  </head>
  <body>
    <!-- navigation bar -->
    <%- include('../components/navbar', { pageHeader: group.name}) %>

    <!-- show about and join button -->
    <header class="group-header">
      <% if (!isMember) { %>
        <div class="group list-item">
          <div class="name"><%= group.name %></div>
          <a href="/groups/<%= group.id %>/join">Join</a>
        </div>  
      <% } else { %>
        <div class="write-message">
          <form class="message-form" action="/groups/<%= group.id %>" method="post">
            <div class="username"><%= user.username %></div>

            <textarea name="message" id="message" placeholder="What is in you mind?"></textarea>
            <button class="post-btn">Post</button>
          </form>
          <% } %>
        </div>
    </header>

    <main>
      <!-- messages -->
      <h2 class="title">Messages</h2>
      <% if (messages.length) { %>
        <% messages.forEach(message => { %>
          <article class="message-post">
            <% if (isAdmin || user.id === message.author_id) { %>
              <button class="message-delete-btn">
                <a href="/groups/<%= group.id %>/messages/<%= message.id %>/delete">
                  <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    <line x1="10" y1="11" x2="10" y2="17"></line>
                    <line x1="14" y1="11" x2="14" y2="17"></line>
                  </svg>
                </a>
              </button>
            <% } %>
            <div class="author"><%= message.author || 'anonymous' %></div>
            <div class="content"><%= message.content %></div>
          </article>
        <% }) %>
      <% } else { %>
        <div class="no-messages">No messages in this group. <br> Be the first to post.</div>
      <% } %>
    </main>
  </body>
</html>
