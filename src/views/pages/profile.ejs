<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <base href="/">
    <link rel="stylesheet" href="style.css">
    <script src="script.js" defer></script>
  </head>
  <body>
    <!-- navbar -->
    <%- include('../components/navbar', {pageHeader: "Profile"}) %>

    <!-- Own Groups list  -->
    <section class="owned-groups">
        <h2 class="section-header">Owned Groups</h2>
        <% if (groups.owned.length) { %>
            <% groups.owned.forEach(group => { %>
              <div class="group list-item">
                <div class="name"><%= group.name %></div>
                <a href="/groups/<%= group.id %>">See Group</a>
              </div>  
           <% }) %>
        <% } else { %>
            <div class="no-messages">No Joined groups</div>
        <% } %>
    </section>

    <!-- Joined Groups list  -->
    <section class="joined-groups">
        <h2 class="section-header">Joined Groups</h2>
        <% if (groups.joined.length) { %>
            <% groups.joined.forEach(group => { %>
              <div class="group list-item">
                <div class="name"><%= group.name %></div>
                <a href="/groups/<%= group.id %>">See Group</a>
              </div>  
           <% }) %>
        <% } else { %>
            <div class="no-messages">No joined groups</div>
        <% } %>
    </section>

    <!-- posted messages  -->
    <section class="profle-messages">
        <h2 class="section-header">Messages</h2>
        <% if (messages.length) { %>
            <% messages.forEach(message => { %>
            <article class="message-post">
                <button class="message-delete-btn">
                    <a href="/groups/<%= message.group.id %>/messages/<%= message.id %>/delete">
                    <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        <line x1="10" y1="11" x2="10" y2="17"></line>
                        <line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                    </a>
                </button>
                <div class="author"><%= message.group.name %></div>
                <div class="content"><%= message.content %></div>
            </article>
            <% }) %>
        <% } else { %>
            <div class="no-messages">No messages</div>
        <% } %>
    </section>
  </body>
</html>
